<div class="container">
  <h2 class="h2-title">Real Time Products</h2>

  <hr class=""/>

  <div class="form-container">
    <div class="form-title">
      <h5>Created Products</h5>
    </div>
    <div class="form-text">
      <form id="form">
        <div class="mb-2">
          <input type="text" class="form-input" name="title" id="title" placeholder="Title" required/>
        </div>
        <div class="mb-2">
          <input type="text" class="form-input" name="description" id="description" placeholder="Description" required/>
        </div>
        <div class="mb-2">
          <input type="number" class="form-input" name="Price" id="Price" step="0.01" placeholder="Price"/>
        </div>
        <div class="mb-2">
          <input type="text" class="form-input" name="code" id="code" placeholder="Code" required/>
        </div>
        <div class="mb-2">
          <input type="text" class="form-input" name="category" id="category" placeholder="Category" />
        </div>
        <div class="mb-2">
          <input type="number" class="form-input" name="Stock" id="Stock" placeholder="Stock" required />
        </div>
        <button type="submit" class="btn-create" id="addProduct">Create Product</button>
      </form>
    </div>
  </div>

  <hr class=""/>

  {{> table}}
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/index.js"></script>